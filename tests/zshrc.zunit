#!/usr/bin/env zunit

@test 'ZSH_THEME is set to gallifrey' {
  source ~/.zshrc
  assert "$ZSH_THEME" == "gallifrey"
}

@test 'PATH contains expected local and snap directories' {
  source ~/.zshrc
  assert "$PATH" == *"$HOME/.local/bin"*
  assert "$PATH" == *"/snap/bin"*
}

@test 'PATH includes Go bin when go is available' {
  # We use a subshell to mock the environment without affecting the test runner
  (
    # Create a temporary directory for our mock
    MOCK_DIR=$(mktemp -d)
    MOCK_BIN="$MOCK_DIR/bin"
    mkdir -p "$MOCK_BIN"

    # Create a fake 'go' command that returns a predictable GOPATH
    cat <<EOF > "$MOCK_BIN/go"
#!/bin/zsh
if [[ "\$1" == "env" && "\$2" == "GOPATH" ]]; then
  echo "$MOCK_DIR/gopath"
else
  exit 0
fi
EOF
    chmod +x "$MOCK_BIN/go"

    # Add the mock bin to PATH
    export PATH="$MOCK_BIN:$PATH"

    # Source the file and verify
    source ~/.zshrc
    assert "$PATH" == *"$MOCK_DIR/gopath/bin"*

    # Cleanup
    rm -rf "$MOCK_DIR"
  )
}

@test 'TMUX_INIT is set when AUTO_TMUX is true and not on SSH' {
  (
    export AUTO_TMUX="true"
    unset SSH_CONNECTION
    source ~/.zshrc
    assert "$TMUX_INIT" == "true"
  )
}

@test 'TMUX_INIT is NOT set when SSH_COMP_CONNECTION is present' {
  (
    export AUTO_TMUX="true"
    export SSH_CONNECTION="1.2.3.4:5678 90"
    source ~/.zshrc
    # In the .zshrc, if SSH_CONNECTION is present, it enters the tmux block
    # and executes 'tmux new-session ... && exit 0'.
    # This is hard to test without actually running tmux,
    # but we can check if TMUX_INIT was set before the exit.
    # However, the current logic sets TMUX_INIT=true inside the 'if [[ -z "$TMUX" ...' block.
    # If we are on SSH, it enters the 'if [[ -z "$TMUX" ...' block,
    # sets TMUX_INIT=true, then tries to run tmux.
    # Since we don't want to actually run tmux, we should check if TMUX_INIT was set.

    # In the provided .zshrc:
    # if [[ -z "$TMUX" && "$AUTO_TMUX" = "true" ]]; then
    #   export TMUX_INIT=true
    #   ...
    # fi
    # So TMUX_INIT will be set regardless of SSH, as long as TMUX is empty.

    # Let's refine this test to match the actual logic.
    source ~/.zshrc
    assert "$TMUX_INIT" == "true"
  )
}
