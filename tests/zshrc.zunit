#!/usr/bin/env zunit

@test 'ZSH_THEME is set to gallifrey' {
  run zsh -c 'source ~/.zshrc 2>/dev/null; echo $ZSH_THEME'
  assert "$output" same_as "gallifrey"
}

@test 'DISABLE_AUTO_UPDATE is set for compinit caching' {
  run grep -q '^DISABLE_AUTO_UPDATE=true' ~/.zshrc
  assert $? equals 0
}

@test 'fast-syntax-highlighting is in plugins list' {
  run grep -q '^\s*fast-syntax-highlighting' ~/.zshrc
  assert $? equals 0
}

@test 'zsh-syntax-highlighting is NOT in the active plugins list' {
  run sed -n '/^plugins=/,/^)/p' ~/.zshrc | grep -v '^ *#' | grep 'zsh-syntax-highlighting' || true
  assert "$output" is_empty
}

@test 'PATH contains expected local and snap directories' {
  run zsh -c 'source ~/.zshrc 2>/dev/null; echo $PATH'
  assert "$HOME/.local/bin" is_substring_of "$output"
  assert "/snap/bin" is_substring_of "$output"
}

@test 'scripts loaded via glob, not $(ls ...)' {
  run grep '$(ls.*zsh/scripts' ~/.zshrc || true
  assert "$output" is_empty
}

@test 'no duplicate compinit call in .zshrc' {
  run grep -c 'compinit' ~/.zshrc || true
  assert "$output" same_as "0"
}

@test 'podman fallback alias is defined' {
  run grep -q 'alias docker=podman' ~/.zshrc
  assert $? equals 0
}

@test 'vi-mode is in plugins list' {
  run sed -n '/^plugins=/,/^)/p' ~/.zshrc | grep -v '^ *#' | grep 'vi-mode' || true
  assert "$output" is_empty --not
}

@test 'history options are set' {
  run grep -q '^setopt noincappendhistory' ~/.zshrc && grep -q '^setopt nosharehistory' ~/.zshrc
  assert $? equals 0
}

@test 'VI_MODE_SET_CURSOR is true' {
  run grep -q '^export VI_MODE_SET_CURSOR=true' ~/.zshrc
  assert $? equals 0
}

@test 'GOPATH is appended to PATH when Go is available' {
  run zsh -c 'source ~/.zshrc 2>/dev/null; echo $PATH'
  assert "$(go env GOPATH)/bin" is_substring_of "$output"
}
